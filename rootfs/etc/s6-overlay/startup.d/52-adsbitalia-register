#!/command/with-contenv bash
# shellcheck shell=bash disable=SC1091,SC2154

source /scripts/common
source /scripts/interpret_ultrafeeder_config


msg() {
    "${s6wrap[@]}" echo "$*"
}

print_compare() {
    local key="$1"
    local old_val="$2"
    local new_val="$3"

    if [[ "$old_val" == "$new_val" ]]; then
        msg "$key: unchanged (\"$new_val\")"
    else
        msg "$key: changed"
        msg "  old: \"$old_val\""
        msg "  new: \"$new_val\""
    fi
}

trim() {
    local s="$1"
    s="${s#"${s%%[![:space:]]*}"}"
    s="${s%"${s##*[![:space:]]}"}"
    printf '%s' "$s"
}

extract_uuid_from_entry() {
    local entry="$1"
    local -a parts
    local part

    readarray -td "," parts < <(printf '%s' "$entry")
    for part in "${parts[@]}"; do
        part="$(trim "$part")"
        if [[ "${part,,}" == uuid=* ]]; then
            printf '%s' "${part#*=}"
            return 0
        fi
    done
    return 1
}

detect_public_ip() {
    local ip
    local provider

    for provider in \
        "https://api.ipify.org" \
        "https://ifconfig.me/ip" \
        "https://icanhazip.com"
    do
        ip="$(curl -fsS --max-time 10 "$provider" 2>/dev/null | tr -d '[:space:]' || true)"
        if [[ "$ip" =~ ^([0-9]{1,3}\.){3}[0-9]{1,3}$ ]]; then
            printf '%s' "$ip"
            return 0
        fi
    done

    return 1
}

generate_token() {
    python3 - <<'PY'
import secrets
print(secrets.token_urlsafe(48))
PY
}

safe_num() {
    local n="$1"
    if [[ "$n" =~ ^[0-9]+$ ]]; then
        printf '%s' "$n"
    else
        printf '0'
    fi
}

REGISTER_URL="https://adsbitalia.it/api/register-feeder"
STATE_DIR="/var/globe_history/adsbitalia"
STATE_FILE="$STATE_DIR/adsbitalia.conf"
FIXED_MLAT_RETURN_PORT="33106"

TEST_MODE=0
if [[ "${1:-}" == "test" ]]; then
    TEST_MODE=1
fi

ULTRA_CFG="${ULTRAFEEDER_CONFIG:-}"
if [[ -z "$ULTRA_CFG" ]]; then
    msg "ULTRAFEEDER_CONFIG is empty; skipping ADSBItalia registration"
    exit 0
fi

ULTRA_CFG="${ULTRA_CFG//$'\n'/}"
ULTRA_CFG="${ULTRA_CFG//$'\r'/}"

ADSB_ENTRY=""
MLAT_ENTRY=""

readarray -td ";" cfg_entries < <(printf '%s' "$ULTRA_CFG")
for raw_entry in "${cfg_entries[@]}"; do
    entry="$(trim "$raw_entry")"
    [[ -z "$entry" ]] && continue

    readarray -td "," parts < <(printf '%s' "$entry")
    type="$(trim "${parts[0]:-}")"
    host="$(trim "${parts[1]:-}")"

    if [[ "${host,,}" != *"adsbitalia.it"* ]]; then
        continue
    fi

    if [[ "${type,,}" == "adsb" ]] && [[ -z "$ADSB_ENTRY" ]]; then
        ADSB_ENTRY="$entry"
    elif [[ "${type,,}" == "mlat" ]] && [[ -z "$MLAT_ENTRY" ]]; then
        MLAT_ENTRY="$entry"
    fi

done

if [[ -z "$ADSB_ENTRY" ]] && [[ -z "$MLAT_ENTRY" ]]; then
    msg "No adsb or mlat entry for adsbitalia.it in ULTRAFEEDER_CONFIG; skipping"
    exit 0
fi

if ! mkdir -p "$STATE_DIR"; then
    msg "Could not create $STATE_DIR; skipping ADSBItalia registration"
    exit 0
fi

PREV_FEEDER_ID=""
PREV_FEEDER_TOKEN=""
PREV_FEEDER_NAME=""
PREV_PUBLIC_IP=""
PREV_HOSTNAME_LOCAL=""
PREV_LOCAL_BEAST_PORT=""
PREV_FEED_HOST=""
PREV_FEED_PORT=""
PREV_MLAT_HOST=""
PREV_MLAT_PORT=""
PREV_MLAT_RETURN_PORT=""
PREV_LAT=""
PREV_LON=""
PREV_ALT=""

HAD_PREV_CONF=0
if [[ -f "$STATE_FILE" ]]; then
    HAD_PREV_CONF=1
    # shellcheck disable=SC1090
    source "$STATE_FILE" || true

    PREV_FEEDER_ID="${FEEDER_ID:-}"
    PREV_FEEDER_TOKEN="${FEEDER_TOKEN:-}"
    PREV_FEEDER_NAME="${FEEDER_NAME:-}"
    PREV_PUBLIC_IP="${PUBLIC_IP:-}"
    PREV_HOSTNAME_LOCAL="${HOSTNAME_LOCAL:-}"
    PREV_LOCAL_BEAST_PORT="${LOCAL_BEAST_PORT:-}"
    PREV_FEED_HOST="${FEED_HOST:-}"
    PREV_FEED_PORT="${FEED_PORT:-}"
    PREV_MLAT_HOST="${MLAT_HOST:-}"
    PREV_MLAT_PORT="${MLAT_PORT:-}"
    PREV_MLAT_RETURN_PORT="${MLAT_RETURN_PORT:-}"
    PREV_LAT="${LAT:-}"
    PREV_LON="${LON:-}"
    PREV_ALT="${ALT:-}"
fi

ADSB_UUID=""
ADSB_HOST=""
ADSB_PORT=""
ADSB_PROTOCOL=""
if [[ -n "$ADSB_ENTRY" ]]; then
    readarray -td "," adsb_parts < <(printf '%s' "$ADSB_ENTRY")
    ADSB_HOST="$(trim "${adsb_parts[1]:-}")"
    ADSB_PORT="$(trim "${adsb_parts[2]:-}")"
    ADSB_PROTOCOL="${adsb_parts[3]:-}"
    ADSB_PROTOCOL="$(trim "$ADSB_PROTOCOL")"
    ADSB_UUID="$(extract_uuid_from_entry "$ADSB_ENTRY" || true)"
fi

MLAT_UUID=""
MLAT_HOST_CFG=""
MLAT_PORT_CFG=""
if [[ -n "$MLAT_ENTRY" ]]; then
    readarray -td "," mlat_parts < <(printf '%s' "$MLAT_ENTRY")
    MLAT_HOST_CFG="$(trim "${mlat_parts[1]:-}")"
    MLAT_PORT_CFG="$(trim "${mlat_parts[2]:-}")"
    MLAT_UUID="$(extract_uuid_from_entry "$MLAT_ENTRY" || true)"
fi

FEEDER_ID="${PREV_FEEDER_ID:-}"
if [[ -z "$FEEDER_ID" ]]; then FEEDER_ID="${ADSB_UUID:-}"; fi
if [[ -z "$FEEDER_ID" ]]; then FEEDER_ID="${MLAT_UUID:-}"; fi
if [[ -z "$FEEDER_ID" ]]; then FEEDER_ID="${UUID:-}"; fi
if [[ -z "$FEEDER_ID" ]]; then FEEDER_ID="$(cat /proc/sys/kernel/random/uuid 2>/dev/null || true)"; fi
if [[ -z "$FEEDER_ID" ]]; then
    msg "No FEEDER_ID available; skipping ADSBItalia registration"
    exit 0
fi

FEEDER_TOKEN="${PREV_FEEDER_TOKEN:-}"
if [[ -z "$FEEDER_TOKEN" ]]; then
    FEEDER_TOKEN="$(generate_token 2>/dev/null || true)"
fi

if [[ -n "$PREV_FEEDER_ID" ]] && [[ "$FEEDER_ID" != "$PREV_FEEDER_ID" ]]; then
    FEEDER_TOKEN="$(generate_token 2>/dev/null || true)"
fi

if [[ -z "$FEEDER_TOKEN" ]]; then
    msg "Could not generate FEEDER_TOKEN; skipping ADSBItalia registration"
    exit 0
fi

FEEDER_NAME="${MLAT_USER:-$FEEDER_ID}"

PUBLIC_IP="$(detect_public_ip || true)"
if [[ -z "$PUBLIC_IP" ]]; then
    PUBLIC_IP="${PREV_PUBLIC_IP:-}"
fi

HOSTNAME_LOCAL="$(hostname -f 2>/dev/null || hostname 2>/dev/null || true)"

case "${ADSB_PROTOCOL,,}" in
    beast_reduce_plus_out|beast_out)
        LOCAL_BEAST_PORT="${READSB_NET_BEAST_OUTPUT_PORT:-30005}"
        ;;
    beast_reduce_out)
        LOCAL_BEAST_PORT="${READSB_NET_BEAST_REDUCE_OUT_PORT:-30006}"
        ;;
    *)
        LOCAL_BEAST_PORT="${READSB_NET_BEAST_OUTPUT_PORT:-30005}"
        ;;
esac
LOCAL_BEAST_PORT="${LOCAL_BEAST_PORT%%,*}"
LOCAL_BEAST_PORT="$(trim "$LOCAL_BEAST_PORT")"
if [[ -z "$LOCAL_BEAST_PORT" ]]; then
    LOCAL_BEAST_PORT="30005"
fi

FEED_HOST="$ADSB_HOST"
FEED_PORT="$ADSB_PORT"
MLAT_HOST="$MLAT_HOST_CFG"
MLAT_PORT="$MLAT_PORT_CFG"
MLAT_RETURN_PORT="$FIXED_MLAT_RETURN_PORT"

LAT="${LAT:-${READSB_LAT:-${PREV_LAT:-}}}"
LON="${LON:-${LONG:-${READSB_LON:-${PREV_LON:-}}}}"
ALT="${ALT:-${READSB_ALT:-${PREV_ALT:-}}}"

LOCAL_BEAST_PORT_NUM="$(safe_num "$LOCAL_BEAST_PORT")"
FEED_PORT_NUM="$(safe_num "$FEED_PORT")"
MLAT_PORT_NUM="$(safe_num "$MLAT_PORT")"
MLAT_RETURN_PORT_NUM="$(safe_num "$MLAT_RETURN_PORT")"

changed=0
if [[ "$FEEDER_ID" != "$PREV_FEEDER_ID" ]]; then changed=1; fi
if [[ "$FEEDER_TOKEN" != "$PREV_FEEDER_TOKEN" ]]; then changed=1; fi
if [[ "$FEEDER_NAME" != "$PREV_FEEDER_NAME" ]]; then changed=1; fi
if [[ "$PUBLIC_IP" != "$PREV_PUBLIC_IP" ]]; then changed=1; fi
if [[ "$HOSTNAME_LOCAL" != "$PREV_HOSTNAME_LOCAL" ]]; then changed=1; fi
if [[ "$LOCAL_BEAST_PORT" != "$PREV_LOCAL_BEAST_PORT" ]]; then changed=1; fi
if [[ "$FEED_HOST" != "$PREV_FEED_HOST" ]]; then changed=1; fi
if [[ "$FEED_PORT" != "$PREV_FEED_PORT" ]]; then changed=1; fi
if [[ "$MLAT_HOST" != "$PREV_MLAT_HOST" ]]; then changed=1; fi
if [[ "$MLAT_PORT" != "$PREV_MLAT_PORT" ]]; then changed=1; fi
if [[ "$MLAT_RETURN_PORT" != "$PREV_MLAT_RETURN_PORT" ]]; then changed=1; fi
if [[ "$LAT" != "$PREV_LAT" ]]; then changed=1; fi
if [[ "$LON" != "$PREV_LON" ]]; then changed=1; fi
if [[ "$ALT" != "$PREV_ALT" ]]; then changed=1; fi

if (( TEST_MODE == 1 )); then
    msg "ADSBItalia registration test mode enabled"
    if (( HAD_PREV_CONF == 1 )); then
        msg "Loaded existing state from $STATE_FILE"
    else
        msg "No existing state file found at $STATE_FILE"
    fi

    print_compare "FEEDER_ID" "$PREV_FEEDER_ID" "$FEEDER_ID"
    print_compare "FEEDER_TOKEN" "$PREV_FEEDER_TOKEN" "$FEEDER_TOKEN"
    print_compare "FEEDER_NAME" "$PREV_FEEDER_NAME" "$FEEDER_NAME"
    print_compare "PUBLIC_IP" "$PREV_PUBLIC_IP" "$PUBLIC_IP"
    print_compare "HOSTNAME_LOCAL" "$PREV_HOSTNAME_LOCAL" "$HOSTNAME_LOCAL"
    print_compare "LOCAL_BEAST_PORT" "$PREV_LOCAL_BEAST_PORT" "$LOCAL_BEAST_PORT"
    print_compare "FEED_HOST" "$PREV_FEED_HOST" "$FEED_HOST"
    print_compare "FEED_PORT" "$PREV_FEED_PORT" "$FEED_PORT"
    print_compare "MLAT_HOST" "$PREV_MLAT_HOST" "$MLAT_HOST"
    print_compare "MLAT_PORT" "$PREV_MLAT_PORT" "$MLAT_PORT"
    print_compare "MLAT_RETURN_PORT" "$PREV_MLAT_RETURN_PORT" "$MLAT_RETURN_PORT"
    print_compare "LAT" "$PREV_LAT" "$LAT"
    print_compare "LON" "$PREV_LON" "$LON"
    print_compare "ALT" "$PREV_ALT" "$ALT"

    if (( changed == 0 )); then
        msg "Judgement: values are unchanged"
    else
        msg "Judgement: values have changed"
    fi
else

    if (( HAD_PREV_CONF == 1 )) && (( changed == 0 )); then
        msg "ADSBItalia registration values unchanged; skipping"
        exit 0
    fi

    if ! {
        printf 'FEEDER_ID=%q\n' "$FEEDER_ID"
        printf 'FEEDER_TOKEN=%q\n' "$FEEDER_TOKEN"
        printf 'FEEDER_NAME=%q\n' "$FEEDER_NAME"
        printf 'PUBLIC_IP=%q\n' "$PUBLIC_IP"
        printf 'HOSTNAME_LOCAL=%q\n' "$HOSTNAME_LOCAL"
        printf 'LOCAL_BEAST_PORT=%q\n' "$LOCAL_BEAST_PORT"
        printf 'FEED_HOST=%q\n' "$FEED_HOST"
        printf 'FEED_PORT=%q\n' "$FEED_PORT"
        printf 'MLAT_HOST=%q\n' "$MLAT_HOST"
        printf 'MLAT_PORT=%q\n' "$MLAT_PORT"
        printf 'MLAT_RETURN_PORT=%q\n' "$MLAT_RETURN_PORT"
        printf 'LAT=%q\n' "$LAT"
        printf 'LON=%q\n' "$LON"
        printf 'ALT=%q\n' "$ALT"
    } > "$STATE_FILE"; then
        msg "Could not write $STATE_FILE; skipping ADSBItalia registration"
        exit 0
    fi

    chmod 600 "$STATE_FILE" || true
fi

PAYLOAD=$(printf '{"feeder_id":"%s","feeder_token":"%s","user":"%s","host":"%s","hostname":"%s","beast_port":%s,"local_beast_port":%s,"feed_host":"%s","feed_port":%s,"feed_mode":"push","mlat_host":"%s","mlat_port":%s,"mlat_return_port":%s,"lat":"%s","lon":"%s","alt":"%s"}' \
    "$FEEDER_ID" \
    "$FEEDER_TOKEN" \
    "$FEEDER_NAME" \
    "$PUBLIC_IP" \
    "$HOSTNAME_LOCAL" \
    "$LOCAL_BEAST_PORT_NUM" \
    "$LOCAL_BEAST_PORT_NUM" \
    "$FEED_HOST" \
    "$FEED_PORT_NUM" \
    "$MLAT_HOST" \
    "$MLAT_PORT_NUM" \
    "$MLAT_RETURN_PORT_NUM" \
    "$LAT" \
    "$LON" \
    "$ALT")

CURL_HEADERS=(-H "Content-Type: application/json")
if (( HAD_PREV_CONF == 1 )); then
    CURL_HEADERS+=(-H "X-Register-Token: ${FEEDER_TOKEN}")
fi

if (( TEST_MODE != 1 )) && curl -fsS \
    "${CURL_HEADERS[@]}" \
    -d "$PAYLOAD" \
    "$REGISTER_URL" >/dev/null; then

    msg "Feeder registration $( (( HAD_PREV_CONF == 1 )) && echo "update " || true )request sent successfully."
    msg "Feeder Name: $FEEDER_NAME"
    msg "Feeder ID: $FEEDER_ID"
    msg "Feeder Token: $FEEDER_TOKEN"
elif (( TEST_MODE != 1 )); then
    msg "Registration failed or was rejected by the server."
    msg "Ultrafeeder will feed adsbitalia without registration."
else
    msg "Test mode: registration request not sent."
    msg "Payload message that would have been sent:"
    msg "$(jq . <<< "$PAYLOAD")"
fi

exit 0
